# Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=thermal-battery-agent-ds1
GOOGLE_CLOUD_LOCATION=asia-south1

# BigQuery
BQ_PROJECT=thermal-battery-agent-ds1
BQ_DATASET=thermal_battery_data

# PostgreSQL
DATABASE_URL=postgresql://resl_user:resl_password@localhost:5432/resl_agent

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
